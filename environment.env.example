# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5

# Anthropic Claude
CLAUDE_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6

# Cisco Catalyst Center
CC_URL=https://your-catalyst-center.example.com
CC_USER=your_username
CC_PASS=your_password
CC_VERSION=2.3.7.9

# Chroma DB server
DB_SERVER=localhost
DB_PORT=8010
DB_COLLECTION=OPS
DB_PATH=VDB

# Project and dataset paths
APPS_PATH=/absolute/path/to/catalyst_center_rag_ops
DATASET=DATASET

# Embedding model
MODEL_NAME=all-MiniLM-L6-v2
# Optional: local embedding model path for offline/corporate environments
# MODEL_LOCAL_PATH=/absolute/path/to/local/model

# Optional: custom CA bundle for HuggingFace/HTTPS in enterprise environments
# HF_CA_BUNDLE=/absolute/path/to/ca-bundle.pem

# Optional: data collection YAML overrides
# DEVICE_LIST_FILE=/absolute/path/to/device_list.yaml
# CLI_COMMANDS_FILE=/absolute/path/to/cli_commands.yaml
